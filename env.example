# Anam
ANAM_API_KEY=your_anam_api_key
ANAM_AVATAR_ID=071b0286-4cce-4808-bee2-e642f1062de3

# Daily (required for AnamTransport / Daily egress)
# Pre-create the room (and for private rooms, mint two meeting tokens) before running.
DAILY_ROOM_URL=https://your-domain.daily.co/your-room
# optional: Meeting token for the Anam avatar
DAILY_AVATAR_TOKEN=your_daily_avatar_meeting_token
# optional: Meeting token for the Pipecat bot itself
DAILY_BOT_TOKEN=your_daily_bot_meeting_token
# Option: Avatar display name. Must match the user_name claim, if any, of DAILY_AVATAR_TOKEN.
# DAILY_AVATAR_USER_NAME=anam-avatar

# STT (Deepgram)
DEEPGRAM_API_KEY=your_deepgram_api_key

# TTS (Cartesia)
CARTESIA_API_KEY=your_cartesia_api_key

# LLM (Google)
GOOGLE_API_KEY=your_google_api_key
